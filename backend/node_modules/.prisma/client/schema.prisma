generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  password     String
  createdAt    DateTime      @default(now())
  transactions Transaction[]
  categories   Category[]
  goals        Goal[]
  budgets      Budget[]
}

model Category {
  id           String        @id @default(cuid())
  name         String
  type         String
  color        String
  isDefault    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]
}

model Transaction {
  id          String   @id @default(cuid())
  type        String
  amount      Float
  description String?
  date        String
  createdAt   DateTime @default(now())
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Goal {
  id            String         @id @default(cuid())
  name          String
  targetAmount  Float
  savedAmount   Float          @default(0)
  deadline      String
  color         String
  completed     Boolean        @default(false)
  createdAt     DateTime       @default(now())
  userId        String
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions Contribution[]
}

model Contribution {
  id        String   @id @default(cuid())
  amount    Float
  date      String
  note      String?
  createdAt DateTime @default(now())
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model Budget {
  id         String   @id @default(cuid())
  amount     Float
  month      String
  createdAt  DateTime @default(now())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, categoryId, month])
}
